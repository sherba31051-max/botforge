generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_FILE_NAME")
}

model User {
  // Adaptive AI platform columns (do not change)
  id     String  @id
  name   String?
  image  String?
  handle String?

  // Additional columns can be added here
}

model BotBlueprint {
  id            String   @id @default(cuid())
  name          String
  category      String
  prompt        String
  platforms     String
  summary       String
  features      String
  commands      String
  integrations  String
  knowledgeBase String
  launchPlan    String
  createdAt     DateTime @default(now())
}

model KnowledgeSnapshot {
  id        String   @id @default(cuid())
  headline  String
  items     String
  sources   String
  sessionId String?
  status    String?
  createdAt DateTime @default(now())
}
